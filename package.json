{
  "name": "terria-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "TerriaJS monorepo: terriajs, terriajs-server, and TerriaMap.",
  "license": "Apache-2.0",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">= 22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run build && yarn workspace terriajs-map start",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "prettier-check": "prettier --check .",
    "sync-readme": "node -e \"require('node:fs').copyFileSync('packages/terriajs/README.md','README.md')\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "3.8.1",
    "pretty-quick": "^4.2.2",
    "turbo": "2.9.16"
  },
  "resolutions": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.1"
  }
}
