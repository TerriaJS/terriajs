{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "ts-out/**", "wwwroot/build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build-for-node": {
      "dependsOn": ["^build-for-node"],
      "outputs": ["build/**", "ts-out/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {}
  }
}
