{
  "compilerOptions": {
    "target": "esNext",
    "module": "esNext",
    "incremental": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "strict": true,
    // Skip type-checking of declaration (.d.ts) files. Required because
    // react-i18next (v17+) augments React's `HTMLAttributes.children` with
    // `ReactI18NextChildren` (which includes `Record<string, unknown>` when
    // `allowObjectInHTMLChildren` is enabled) but not the base
    // `DOMAttributes.children`, so `@types/react` reports `HTMLAttributes`
    // as "incorrectly extending" `DOMAttributes`. See lib/ThirdParty/i18n/i18next.d.ts.
    // @TODO: Revisit this when updating react-i18next, react or ts dependencies
    "skipLibCheck": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noUncheckedSideEffectImports": true,
    "isolatedModules": true,
    "outDir": "ts-out",
    "resolveJsonModule": true,
    "typeRoots": [
      "./lib/ThirdParty/",
      "./node_modules/",
      "./node_modules/@types/",
      "../node_modules/",
      "../node_modules/@types/",
      "../../node_modules/",
      "../../node_modules/@types/",
      "../../../node_modules/",
      "../../../node_modules/@types/"
    ],
    "preserveSymlinks": true,
    "types": ["terriajs-cesium", "@testing-library/jasmine-dom"]
  },
  "include": ["./lib/**/*", "./test/**/*", "./buildprocess/**/*"]
}
